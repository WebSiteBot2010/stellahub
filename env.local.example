# =====================================================
# SOLLARY - Environment Variables
# Copia questo file come .env.local e compila i valori
# =====================================================

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_key_here_change_this

# Discord OAuth2 (crea app su https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord Bot Token (per check ban e assegnazione ruoli)
DISCORD_BOT_TOKEN=your_discord_bot_token

# Il tuo Server Discord ID
DISCORD_GUILD_ID=your_guild_id

# Webhook URLs (crea webhook nei canali Discord desiderati)
DISCORD_WEBHOOK_UNBAN=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_VOTE=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_PARTNERSHIP=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_PARTNERSHIP_PUBLISH=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_CANDIDATURE=https://discord.com/api/webhooks/...

# Role IDs
DISCORD_VOTER_ROLE_ID=your_voter_role_id

# Staff Role IDs (chi può gestire partnership)
DISCORD_STAFF_ROLE_IDS=role_id_1,role_id_2

# Secret per webhook security
WEBHOOK_SECRET=your_webhook_secret_here
